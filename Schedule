<script>
  function switchTab(t){
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.getElementById('panel-'+t).classList.add('active');
    document.querySelector('[data-tab="'+t+'"]').classList.add('active');
  }

  function updateCountdown(){
    const trip=new Date(2025,4,23);
    const now=new Date();
    const diff=trip-now;
    const el=document.getElementById('countdown'); el.style.display="none";
    if(diff>0){
      const d=Math.floor(diff/(1000*60*60*24));
      const h=Math.floor((diff%(1000*60*60*24))/(1000*60*60));
      const m=Math.floor((diff%(1000*60*60))/(1000*60));
      el.innerHTML=`🏖️ Let's DO This — trip starts in <span>${d}</span> days <span>${h}</span> hrs <span>${m}</span> min!`;
    } else if(diff>-7*24*3600*1000){
      el.textContent="🎉 THE PARTY IS HAPPENING RIGHT NOW! Happy 60th Kat! 🎂🏖️";
    } else {
      el.textContent="🥂 What an incredible trip! Happy 60th Kat — here's to many more adventures!";
    }
  }
  updateCountdown(); setInterval(updateCountdown,30000);

  // Packing checkboxes
  document.querySelectorAll('.pack-cat').forEach((cat,ci)=>{
    cat.querySelectorAll('.pack-item input').forEach((cb,ii)=>{
      try{if(localStorage.getItem('p'+ci+'_'+ii)==='true'){cb.checked=true;cb.closest('.pack-item').classList.add('checked');}}catch(e){}
      cb.addEventListener('change',updatePacking);
    });
  });
  function updatePacking(){
    document.querySelectorAll('.pack-cat').forEach((cat,ci)=>{
      const items=cat.querySelectorAll('.pack-item input');
      const fill=cat.querySelector('.pack-prog-fill');
      let n=0;
      items.forEach((cb,ii)=>{
        if(cb.checked)n++;
        cb.closest('.pack-item').classList.toggle('checked',cb.checked);
        try{localStorage.setItem('p'+ci+'_'+ii,cb.checked);}catch(e){}
      });
      fill.style.width=items.length?(n/items.length*100)+'%':'0%';
    });
  }
  updatePacking();
</script>

