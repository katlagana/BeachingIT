<title>🏖️ Let's DO This! · Ocean Isle Beach</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --sun:#FFD166;--coral:#EF476F;--teal:#06D6A0;--sky:#118AB2;
    --lavender:#A78BFA;--mint:#B7F0E4;--peach:#FFD6C0;
    --bg:#FFF9F0;--card:#FFFFFF;--text:#2D2A32;--muted:#7C7A85;--border:#E8E0D8;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;
    background-image:radial-gradient(circle,var(--sun) 2px,transparent 2px),
      radial-gradient(circle,var(--coral) 2px,transparent 2px),
      radial-gradient(circle,var(--teal) 2px,transparent 2px);
    background-size:90px 90px,130px 130px,110px 110px;
    background-position:15px 15px,55px 45px,25px 75px;
    opacity:.12;pointer-events:none;z-index:0;}
  .wrapper{position:relative;z-index:1;}

/* HERO */
.hero{
background: url(‘data:image/jpeg;base64,’) center center / cover no-repeat;
padding:72px 24px 90px;text-align:center;
position:relative;overflow:hidden;clip-path:ellipse(110% 100% at 50% 0%);}
/* dark + coral gradient overlay so text pops */
.hero::before{content:’’;position:absolute;inset:0;
background:linear-gradient(160deg,rgba(20,10,5,.55) 0%,rgba(196,98,45,.45) 50%,rgba(6,40,35,.5) 100%);
z-index:0;}
.hero::after{content:’’;} /* disable emoji placeholder */
.hero>*{position:relative;z-index:1;}
@keyframes float{0%,100%{transform:translateY(0) rotate(-5deg);}50%{transform:translateY(-12px) rotate(5deg);}}
.trip-emoji{font-size:52px;display:block;margin-bottom:12px;animation:bounce 2.2s ease-in-out infinite;
filter:drop-shadow(2px 3px 6px rgba(0,0,0,.5));}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
.hero h1{font-family:‘Fredoka One’,cursive;font-size:clamp(36px,6vw,72px);color:#fff;
text-shadow:3px 3px 0 rgba(0,0,0,.4), 0 0 40px rgba(0,0,0,.3);margin-bottom:8px;}
.hero-dates{font-size:16px;color:rgba(255,255,255,.95);font-weight:700;margin-bottom:5px;
text-shadow:1px 1px 4px rgba(0,0,0,.6);}
.hero-loc{font-size:14px;color:rgba(255,255,255,.88);font-weight:600;
text-shadow:1px 1px 4px rgba(0,0,0,.6);}

/* COUNTDOWN */
.countdown-bar{background:var(–coral);color:#fff;text-align:center;padding:7px 20px;
font-family:‘Fredoka One’,cursive;font-size:13px;letter-spacing:.5px;min-height:0;}
.countdown-bar span{font-size:24px;margin:0 4px;}

/* TABS */
.tabs{display:flex;justify-content:center;flex-wrap:wrap;gap:10px;padding:26px 20px 0;max-width:1200px;margin:0 auto;}
.tab-btn{background:var(–card);border:2.5px solid transparent;border-radius:50px;padding:15px 28px;
font-family:‘Nunito’,sans-serif;font-size:17px;font-weight:800;cursor:pointer;transition:all .2s;
box-shadow:0 3px 10px rgba(0,0,0,.08);}
.tab-btn:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(0,0,0,.12);}
.tab-btn.active{color:#fff;transform:translateY(-2px);}
.tab-btn[data-tab=“schedule”].active{background:var(–sky);}
.tab-btn[data-tab=“crew”].active{background:var(–coral);}
.tab-btn[data-tab=“stays”].active{background:var(–teal);color:#1a4a40;}
.tab-btn[data-tab=“packing”].active{background:var(–lavender);}
.tab-btn[data-tab=“notes”].active{background:var(–sun);color:#5a3a00;}

/* CONTENT */
.content{max-width:1200px;margin:0 auto;padding:28px 16px 60px;}
.panel{display:none;animation:fadeIn .3s ease;}
.panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.section-title{font-family:‘Fredoka One’,cursive;font-size:26px;margin-bottom:20px;display:flex;align-items:center;gap:10px;}

/* ══════════════════════════════
WEEKLY TABLE
══════════════════════════════ */
.grid-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;
border-radius:16px;box-shadow:0 6px 30px rgba(0,0,0,.12);}

.week-table{border-collapse:collapse;min-width:900px;width:100%;
border-radius:16px;overflow:hidden;}

/* Column widths */
.week-table col.c-label{width:100px;}
.week-table col.c-day{width:calc((100% - 100px)/7);}

/* Day header row */
.week-table thead th{padding:12px 8px;text-align:center;
font-family:‘Fredoka One’,cursive;font-size:14px;color:#fff;
text-shadow:1px 1px 0 rgba(0,0,0,.2);line-height:1.3;border:none;}
.week-table thead th .dn{font-size:16px;display:block;}
.week-table thead th .dd{font-size:10px;opacity:.88;font-family:‘Nunito’,sans-serif;font-weight:700;}
th.corner{background:#2D2A32;}
th.col-sat1{background:linear-gradient(160deg,#118AB2,#06D6A0);}
th.col-sun {background:linear-gradient(160deg,#EF476F,#FFD166);}
th.col-mon {background:linear-gradient(160deg,#A78BFA,#EF476F);}
th.col-tue {background:linear-gradient(160deg,#06D6A0,#118AB2);}
th.col-wed {background:linear-gradient(160deg,#FFD166,#EF476F);}
th.col-thu {background:linear-gradient(160deg,#118AB2,#A78BFA);}
th.col-fri {background:linear-gradient(160deg,#EF476F,#FFD166);}

/* Row label cells */
td.rl{background:#2D2A32;color:rgba(255,255,255,.85);
font-family:‘Fredoka One’,cursive;font-size:10px;
text-align:center;vertical-align:middle;
padding:8px 5px;line-height:1.35;letter-spacing:.3px;
border:1px solid rgba(255,255,255,.07);}

/* Data cells — default */
td.gc{background:#fff;border:1px solid var(–border);
padding:9px 10px;vertical-align:top;}
td.gc.empty{background:#fafaf8;}
td.gc:hover{background:#fffbf5;}

/* Merged span cells */
td.gc.span-mid{text-align:center;vertical-align:middle;}

/* ── Name lists ── */
.names{list-style:none;margin:0;padding:0;}
.names li{font-size:11px;font-weight:700;color:#3b2060;
padding:2px 0;border-bottom:1px dashed #e8e0f0;line-height:1.4;}
.names li:last-child{border-bottom:none;}

/* ── Guest star pills ── */
.guest-pill{display:inline-block;background:#fff8ed;border:1.5px solid #f0c878;
color:#7a4800;border-radius:50px;padding:3px 11px;
font-size:10.5px;font-weight:800;margin:3px 3px 3px 0;line-height:1.4;}

/* ── Meal / event chips ── */
.chip{display:block;border-radius:7px;padding:5px 8px;
font-size:10.5px;font-weight:700;line-height:1.45;
margin-bottom:4px;width:100%;}
.chip:last-child{margin-bottom:0;}
.ch-coral {background:#fde8ee;color:#b01a40;}
.ch-teal  {background:#d4f7ee;color:#0a7050;}
.ch-sky   {background:#d6ecf7;color:#0a527a;}
.ch-sun   {background:#fff3cc;color:#7a5000;}
.ch-lav   {background:#ede8ff;color:#5030a0;}
.ch-green {background:#e2f5e2;color:#286028;}
.ch-peach {background:#ffeae0;color:#903818;}
.ch-grey  {background:#f2f0f5;color:#524d6a;}
.ct{font-size:9px;opacity:.72;display:block;margin-bottom:1px;font-weight:700;letter-spacing:.3px;}
.cn{display:block;font-size:10.5px;}
.cd{display:block;font-size:9.5px;font-weight:600;opacity:.78;margin-top:1px;}

/* all-day food span cell */
td.food-span{background:#f2fdf5;text-align:left;vertical-align:middle;padding:9px 14px;}
.food-items{display:flex;flex-wrap:wrap;gap:6px;}
.food-tag{background:#d4f7ee;color:#0a7050;border-radius:6px;
padding:4px 9px;font-size:10.5px;font-weight:700;}

/* CREW */
.crew-section{margin-bottom:26px;}
.crew-section h3{font-family:‘Fredoka One’,cursive;font-size:18px;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.crew-grid{display:flex;flex-wrap:wrap;gap:9px;}
.crew-tag{padding:9px 16px;border-radius:50px;font-size:13px;font-weight:800;box-shadow:0 2px 8px rgba(0,0,0,.08);}
.c-house{background:#FFD6C0;color:#8a3010;}
.c-guest{background:#B7F0E4;color:#0a5a40;}
.c-vip{background:#fde8ee;color:#c0204a;border:2px solid var(–coral);}

/* STAYS */
.stays-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;}
.stay-card{background:var(–card);border-radius:18px;padding:22px;
box-shadow:0 4px 16px rgba(0,0,0,.07);border-top:5px solid var(–coral);transition:transform .2s;}
.stay-card:hover{transform:translateY(-3px);}
.stay-card:nth-child(2){border-top-color:var(–teal);}
.stay-card:nth-child(3){border-top-color:var(–lavender);}
.stay-emoji{font-size:30px;margin-bottom:10px;display:block;}
.stay-card h3{font-family:‘Fredoka One’,cursive;font-size:18px;margin-bottom:8px;}
.stay-detail{font-size:13px;color:var(–muted);margin-bottom:5px;display:flex;gap:8px;}
.stay-detail strong{color:var(–text);min-width:72px;flex-shrink:0;}
.stay-confirm{display:inline-block;margin-top:10px;background:#e8faf4;color:#059669;
font-size:11px;font-weight:800;padding:4px 12px;border-radius:50px;}

/* PACKING */
.packing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;}
.pack-cat{background:var(–card);border-radius:18px;padding:20px;box-shadow:0 4px 16px rgba(0,0,0,.07);}
.pack-cat h3{font-family:‘Fredoka One’,cursive;font-size:17px;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.pack-prog{height:6px;background:#f0eee8;border-radius:10px;margin-bottom:12px;overflow:hidden;}
.pack-prog-fill{height:100%;background:linear-gradient(90deg,var(–teal),var(–sky));border-radius:10px;transition:width .4s;}
.pack-item{display:flex;align-items:center;gap:10px;padding:7px 0;
border-bottom:1px dashed #f0eee8;font-size:13px;cursor:pointer;transition:opacity .2s;}
.pack-item:last-child{border-bottom:none;}
.pack-item input{accent-color:var(–teal);width:16px;height:16px;cursor:pointer;flex-shrink:0;}
.pack-item.checked{opacity:.4;text-decoration:line-through;}

/* NOTES */
.notes-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;}
.note-card{background:var(–card);border-radius:18px;padding:22px;box-shadow:0 4px 16px rgba(0,0,0,.07);}
.note-card h3{font-family:‘Fredoka One’,cursive;font-size:17px;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.note-item{font-size:13px;color:var(–muted);padding:6px 0;border-bottom:1px dashed #f0eee8;line-height:1.5;}
.note-item:last-child{border-bottom:none;}
.note-item strong{color:var(–text);display:block;font-size:11.5px;margin-bottom:1px;}
.hi-box{background:linear-gradient(135deg,#fff3cc,#ffe69c);border-radius:14px;padding:16px;
margin-bottom:20px;font-size:13px;line-height:1.6;border-left:4px solid var(–sun);}
.hi-box strong{display:block;font-family:‘Fredoka One’,cursive;font-size:16px;margin-bottom:4px;color:#92400e;}

.footer{text-align:center;padding:28px 20px;font-size:12px;color:var(–muted);position:relative;z-index:1;}
</style>

</head>
